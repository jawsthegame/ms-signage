# Port to run the server on (default: 3000)
PORT=3000

# Optional: Set your Sonos speaker IP directly to skip auto-discovery
# Run `node -e "require('node-sonos').DeviceDiscovery(d => console.log(d.host))"` to find it
SONOS_IP=

# Optional: Name of the shop shown in the header
SHOP_NAME=Coffee

# Google Sheets availability (milks + syrups)
# Sheet columns: ID | NAME | AVAILABLE (TRUE/FALSE)
# Sheet must be shared publicly (view access) or with the API key's project
GOOGLE_SHEET_ID=
GOOGLE_API_KEY=
